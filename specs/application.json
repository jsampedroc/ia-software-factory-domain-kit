{
    "domain_model": "{\n  \"domainKit\": {\n    \"boundedContexts\": [\n      {\n        \"name\": \"SchoolManagement\",\n        \"description\": \"Gestiona la informaci\u00f3n central del colegio, sus aulas y la asignaci\u00f3n de alumnos.\",\n        \"modules\": [\n          {\n            \"name\": \"School\",\n            \"entities\": [\n              {\n                \"name\": \"School\",\n                \"attributes\": [\"id\", \"name\", \"address\", \"phoneNumber\", \"active\"],\n                \"businessRules\": [\"El nombre del colegio es obligatorio y \u00fanico en el sistema.\", \"Solo colegios activos pueden tener aulas activas.\"]\n              },\n              {\n                \"name\": \"Classroom\",\n                \"attributes\": [\"id\", \"gradeLevel\", \"section\", \"academicYear\", \"capacity\", \"tutorTeacherId\", \"schoolId\", \"active\"],\n                \"businessRules\": [\"El identificador de aula debe ser \u00fanico por colegio y a\u00f1o acad\u00e9mico.\", \"La capacidad debe ser un n\u00famero positivo.\", \"Un aula no puede superar su capacidad m\u00e1xima de alumnos.\"]\n              }\n            ]\n          },\n          {\n            \"name\": \"Student\",\n            \"entities\": [\n              {\n                \"name\": \"Student\",\n                \"attributes\": [\"id\", \"legalGuardianId\", \"firstName\", \"lastName\", \"dateOfBirth\", \"identificationNumber\", \"enrollmentDate\", \"active\", \"currentClassroomId\"],\n                \"businessRules\": [\"El n\u00famero de identificaci\u00f3n debe ser \u00fanico.\", \"Un alumno debe estar asociado a un tutor legal registrado.\", \"La fecha de nacimiento debe ser anterior a la fecha de inscripci\u00f3n.\"]\n              },\n              {\n                \"name\": \"LegalGuardian\",\n                \"attributes\": [\"id\", \"firstName\", \"lastName\", \"email\", \"primaryPhone\", \"secondaryPhone\", \"address\"],\n                \"businessRules\": [\"El email y al menos un tel\u00e9fono son obligatorios.\", \"El email debe tener un formato v\u00e1lido.\"]\n              }\n            ]\n          }\n        ]\n      },\n      {\n        \"name\": \"Attendance\",\n        \"description\": \"Registra y controla la asistencia diaria de los alumnos.\",\n        \"modules\": [\n          {\n            \"name\": \"Tracking\",\n            \"entities\": [\n              {\n                \"name\": \"DailyAttendance\",\n                \"attributes\": [\"id\", \"classroomId\", \"date\", \"schoolId\"],\n                \"businessRules\": [\"Solo se puede crear un registro de asistencia diaria por aula y fecha.\", \"La fecha no puede ser futura.\"]\n              },\n              {\n                \"name\": \"AttendanceRecord\",\n                \"attributes\": [\"id\", \"dailyAttendanceId\", \"studentId\", \"status\", \"notes\", \"recordedAt\"],\n                \"businessRules\": [\"El estado debe ser uno de: PRESENT, ABSENT, LATE, EXCUSED.\", \"Un alumno solo puede tener un registro por d\u00eda en un aula espec\u00edfica.\", \"El registro se asocia autom\u00e1ticamente al aula del alumno en esa fecha.\"]\n              }\n            ]\n          }\n        ]\n      },\n      {\n        \"name\": \"Billing\",\n        \"description\": \"Gestiona la facturaci\u00f3n mensual, conceptos de cobro y pagos.\",\n        \"modules\": [\n          {\n            \"name\": \"Invoicing\",\n            \"entities\": [\n              {\n                \"name\": \"BillingConcept\",\n                \"attributes\": [\"id\", \"name\", \"description\", \"defaultAmount\", \"periodicity\", \"applicableFromGrade\", \"applicableToGrade\", \"active\"],\n                \"businessRules\": [\"El nombre del concepto debe ser \u00fanico.\", \"El monto por defecto debe ser mayor o igual a cero.\", \"La periodicidad debe ser: MONTHLY, ANNUAL, ONE_TIME.\"]\n              },\n              {\n                \"name\": \"MonthlyInvoice\",\n                \"attributes\": [\"id\", \"studentId\", \"billingPeriod\", \"issueDate\", \"dueDate\", \"totalAmount\", \"status\", \"schoolId\"],\n                \"businessRules\": [\"El per\u00edodo de facturaci\u00f3n (YYYY-MM) debe ser \u00fanico por alumno.\", \"La fecha de vencimiento debe ser posterior a la de emisi\u00f3n.\", \"El estado inicial es PENDING.\", \"El total se calcula sumando los \u00edtems de la factura.\"]\n              },\n              {\n                \"name\": \"InvoiceItem\",\n                \"attributes\": [\"id\", \"monthlyInvoiceId\", \"billingConceptId\", \"description\", \"quantity\", \"unitPrice\", \"subtotal\"],\n                \"businessRules\": [\"El subtotal se calcula como cantidad * precio unitario.\", \"La cantidad debe ser 1 para conceptos no cuantificables (ej. matr\u00edcula).\"]\n              }\n            ]\n          },\n          {\n            \"name\": \"Payment\",\n            \"entities\": [\n              {\n                \"name\": \"Payment\",\n                \"attributes\": [\"id\", \"monthlyInvoiceId\", \"amount\", \"paymentDate\", \"paymentMethod\", \"transactionReference\", \"confirmed\"],\n                \"businessRules\": [\"El monto del pago debe ser mayor a cero.\", \"El m\u00e9todo de pago debe ser uno de: CASH, BANK_TRANSFER, CREDIT_CARD, DEBIT_CARD.\", \"Un pago confirmado actualiza el estado de la factura asociada.\"]\n              }\n            ]\n          }\n        ]\n      }\n    ],\n    \"sharedKernel\": {\n      \"name\": \"Shared\",\n      \"valueObjects\": [\n        {\n          \"name\": \"Money\",\n          \"attributes\": [\"amount\", \"currency\"],\n          \"businessRules\": [\"El monto no puede ser negativo.\", \"La moneda debe ser un c\u00f3digo ISO 4217 v\u00e1lido (ej. USD).\"]\n        },\n        {\n          \"name\": \"DateRange\",\n          \"attributes\": [\"startDate\", \"endDate\"],\n          \"businessRules\": [\"La fecha de inicio debe ser anterior o igual a la fecha de fin.\"]\n        },\n        {\n          \"name\": \"PersonName\",\n          \"attributes\": [\"firstName\", \"lastName\"],\n          \"businessRules\": [\"El nombre y apellido no pueden estar vac\u00edos.\", \"Deben tener una longitud m\u00e1xima definida.\"]\n        }\n      ]\n    },\n    \"technicalPackage\": \"com.application\"\n  }\n}",
